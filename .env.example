# ──────────────────────────────────────────────
# MultiPost Landing — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# These variables are used by the Vercel serverless
# function (api/waitlist.js) for the contact form.
# Set them in Vercel Dashboard → Settings → Environment Variables.
# ──────────────────────────────────────────────

# SMTP server configuration (e.g. Gmail, Zoho, SendGrid, AWS SES)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true

# Email account used to send and receive contact form messages
EMAIL_USER=you@example.com
EMAIL_PASS=your-email-password-or-app-password
