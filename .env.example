# ──────────────────────────────────────────────
# MultiPost Landing — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# These variables are used by the Vercel serverless
# function (api/waitlist.js) for the contact form.
# Set them in Vercel Dashboard → Settings → Environment Variables.
# ──────────────────────────────────────────────

# SMTP server configuration (Zoho recommended — SPF/DKIM/DMARC already
# aligned with multipost.pro). Port 465 = implicit TLS (secure=true);
# port 587 = STARTTLS (secure=false).
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true

# Inbox that receives contact-form submissions. Reply-to is set to the
# visitor's email so support can hit Reply directly.
EMAIL_USER=support@multipost.pro
# Use a Zoho app-specific password (Account → Security → App Passwords),
# never the raw account password.
EMAIL_PASS=your-zoho-app-specific-password

# Branded From address for the outbound visitor confirmation. Must be a
# verified send-as alias of EMAIL_USER on Zoho, otherwise the SMTP
# server will reject mismatched From headers. Defaults to EMAIL_USER if
# unset.
MAIL_FROM_SUPPORT=MultiPost Support <support@multipost.pro>
